# ============================================================================
#  REQUIRED — You need these to run OpenClaw
# ============================================================================

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=...

# ============================================================================
#  RECOMMENDED — Security & identity
# ============================================================================

# Joining code — users must send this before the bot responds (leave empty to disable)
TELEGRAM_JOIN_CODE=

# Comma-separated Telegram user IDs to allow (leave empty to allow anyone with the join code)
TELEGRAM_ALLOWED_USER_IDS=

# Admin user ID — receives debug info via Telegram when users type the support keyword
TELEGRAM_ADMIN_USER_ID=

# Admin email — receives support emails when users type the support keyword (requires Gmail configured)
ADMIN_EMAIL=

# Support keyword — users type this to send debug info to admin (default: "support")
SUPPORT_KEYWORD=support

# GitHub personal access token (needed for creating PRs — get from github.com/settings/tokens with 'repo' scope)
GITHUB_TOKEN=...

# Git identity for commits
GIT_AUTHOR_EMAIL=openclaw@bot.local
GIT_AUTHOR_NAME=OpenClaw Bot

# ============================================================================
#  OPTIONAL — Google APIs (Gmail, Calendar, Todos)
# ============================================================================
#
# These all share the same OAuth2 credentials. Set up once, get email +
# calendar + todos.
#
# Required Google API scopes (select ALL of these in OAuth Playground):
#   • https://mail.google.com/                          (Gmail)
#   • https://www.googleapis.com/auth/calendar           (Calendar)
#   • https://www.googleapis.com/auth/tasks              (Todos)
#
# How to get these credentials:
#   1. Go to console.cloud.google.com → create or select a project
#   2. Enable these APIs: Gmail API, Google Calendar API, Google Tasks API
#   3. Go to APIs & Services → OAuth consent screen → External → add your email as test user
#   4. Go to Credentials → Create Credentials → OAuth client ID → Web application
#      - Add redirect URI: https://developers.google.com/oauthplayground
#      - Copy the Client ID and Client Secret
#   5. Go to https://developers.google.com/oauthplayground/
#      - ⚙️ Settings → check "Use your own OAuth credentials" → paste Client ID and Secret
#      - Select ALL THREE scopes listed above
#      - Authorize APIs → sign in → Exchange authorization code for tokens
#      - Copy the Refresh Token

GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REFRESH_TOKEN=...
GMAIL_USER_EMAIL=you@gmail.com

# ============================================================================
#  OPTIONAL — Roundup Emails
# ============================================================================

# Who to send roundup emails to
ROUNDUP_EMAIL_TO=
ROUNDUP_EMAIL_FROM=

# --- Daily Roundup (sent every day) ---

# News topics (comma-separated)
ROUNDUP_DAILY_TOPICS=AI,startups,cybersecurity

# Twitter handles to include (comma-separated, no @ symbol)
ROUNDUP_TWITTER_HANDLES=

# People to track in the news (comma-separated, hyphenated names e.g. satya-nadella)
ROUNDUP_LINKEDIN_NAMES=

# --- Weekly Roundup (sent once a week) ---

# Deep-dive topics for the weekly digest (comma-separated)
ROUNDUP_WEEKLY_TOPICS=machine learning,venture capital

# Day of week to send the weekly roundup (lowercase)
ROUNDUP_WEEKLY_DAY=saturday

# Hour to send roundups in EST (24h format, default: 9 = 9am EST)
ROUNDUP_SEND_HOUR=9

# --- API Keys ---

# X/Twitter API v2 bearer token (get from developer.x.com — credit-based pricing)
# Used to fetch actual tweets from followed handles in the daily roundup
X_BEARER_TOKEN=

# ============================================================================
#  OPTIONAL — AI Restaurant Reservations
# ============================================================================

# Bland.ai API key for AI phone calls (get from app.bland.ai)
BLAND_API_KEY=
# Google Places API key for automatic phone number lookup
# (enable Places API in your Google Cloud project, then create an API key)
GOOGLE_PLACES_API_KEY=
# Name the AI gives the restaurant for the reservation
RESERVATION_CALLER_NAME=

# ============================================================================
#  OPTIONAL — Advanced / Deployment
# ============================================================================

# Override AI model (defaults shown)
ANTHROPIC_MODEL=claude-opus-4-6
# Use OpenAI instead of Anthropic
# LLM_PROVIDER=openai
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-5

# Rate limiting (per user)
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW=30000

# Server port (default: 8080)
PORT=8080

# Sandbox behavior
OPENCLAW_WORKDIR=/tmp/openclaw-jobs
OPENCLAW_RUN_TESTS=0
CI=1

# Brain — local-first memory with optional GCS backup
OPENCLAW_BRAIN_DIR=/tmp/openclaw-brain
OPENCLAW_BRAIN_BUCKET=your-gcs-bucket-name
OPENCLAW_BRAIN_PREFIX=openclaw-brain

# ============================================================================
#  OPTIONAL — Learn to Code (interactive coding tutor via Telegram)
# ============================================================================

# GitHub repo containing the lesson plan (syllabus.md + lessons/ folder)
LEARN_REPO=org/learn

# Repo for hands-on projects — each learner gets their own subfolder
LEARN_PROJECT_REPOS=org/learn-projects

# Repos to auto-index at startup (comma-separated owner/repo)
OPENCLAW_REPOS=

# GCP — for GCS backup + Compute Engine deployment
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# GCE VM settings (used by deploy-gce.sh and setup.sh)
OPENCLAW_INSTANCE=openclaw-vm
OPENCLAW_MACHINE_TYPE=e2-medium
# GCP_ZONE=us-central1-a
# GCP_SA_KEY_B64=base64-of-service-account-json
